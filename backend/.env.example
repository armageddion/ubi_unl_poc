# Solume API Configuration
SOLUME_BASE_URL=https://eastus.common.solumesl.com
SOLUME_USERNAME=your_username_here
SOLUME_PASSWORD=your_password_here
SOLUME_COMPANY=your_company_here
SOLUME_STORE=your_store_here

# API endpoints
SOLUME_ENDPOINT_1=/common/api/v2/labels/page
